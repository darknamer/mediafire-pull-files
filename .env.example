# MediaFire credentials (required for folder listing and download)
MEDIAFIRE_EMAIL=your.email@example.com
MEDIAFIRE_PASSWORD=your_password

# Optional: folder to download (otherwise pass as first argument)
# MEDIAFIRE_FOLDER=https://www.mediafire.com/folder/XXXXX/FolderName

# Optional: output directory (default: ./downloads)
# MEDIAFIRE_OUTPUT=./downloads

# Optional: MediaFire App ID (default: 42511)
# MEDIAFIRE_APP_ID=42511
